{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WindowsLanguageWidget",
  "version": "1.0.0",
  "identifier": "com.mykolamoskal.windowslanguagewidget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "widget",
        "title": "WindowsLanguageWidget",
        "url": "index.html",
        "width": 240,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": true
      },
      {
        "label": "settings",
        "title": "KeyboardLangLock Settings",
        "url": "settings.html",
        "width": 360,
        "height": 470,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
